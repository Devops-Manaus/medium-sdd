# ── Provider ──────────────────────────────────────────────────────
# Valores suportados:
#   ollama_local     -> Ollama local (localhost)
#   ollama_cloud     -> Ollama cloud (conta logada)
#   openrouter_free  -> OpenRouter free tier
LLM_PROVIDER=openrouter_free

# ── Modelos por role (obrigatório) ────────────────────────────────
# Ajuste conforme o provider acima.
LLM_MODEL_RESEARCHER=z-ai/glm-4.5-air:free
LLM_MODEL_ANALYST=z-ai/glm-4.5-air:free
LLM_MODEL_WRITER=z-ai/glm-4.5-air:free
LLM_MODEL_CRITIC=z-ai/glm-4.5-air:free

# ── OpenRouter free ───────────────────────────────────────────────
OPENROUTER_API_KEY=sua_chave_aqui
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── Ollama local ──────────────────────────────────────────────────
# O padrão já é esse valor.
# OLLAMA_LOCAL_BASE_URL=http://localhost:11434

# ── Ollama cloud ──────────────────────────────────────────────────
# Se o endpoint cloud exigir token, informe em OLLAMA_CLOUD_API_KEY.
# OLLAMA_CLOUD_BASE_URL=https://ollama.com
# OLLAMA_CLOUD_API_KEY=
